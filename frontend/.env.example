# API Configuration
EXPO_PUBLIC_API_BASE_URL=https://api.swibber.com/v1
EXPO_PUBLIC_WS_URL=wss://ws.swibber.com

# Maps
EXPO_PUBLIC_GOOGLE_MAPS_API_KEY=your_google_maps_api_key_here

# Payments
EXPO_PUBLIC_RAZORPAY_KEY_ID=your_razorpay_key_id_here

# Sentry (error tracking)
EXPO_PUBLIC_SENTRY_DSN=your_sentry_dsn_here

# Firebase (push notifications)
EXPO_PUBLIC_FIREBASE_PROJECT_ID=swibber-prod
EXPO_PUBLIC_FIREBASE_APP_ID=your_firebase_app_id_here
EXPO_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=your_sender_id_here

# Feature Flags
EXPO_PUBLIC_ENABLE_FOOD_MODULE=true
EXPO_PUBLIC_ENABLE_PARCEL_MODULE=true
EXPO_PUBLIC_ENABLE_SWIBBER_GOLD=true

# Environment
EXPO_PUBLIC_ENV=development
