{
  "extends": "expo/tsconfig.base",
  "compilerOptions": {
    "strict": true,
    "baseUrl": ".",
    "paths": {
      "@theme": ["./theme/index.ts"],
      "@components/*": ["./components/*"],
      "@screens/*": ["./screens/*"],
      "@navigation/*": ["./navigation/*"],
      "@context/*": ["./context/*"],
      "@store/*": ["./store/*"],
      "@hooks/*": ["./hooks/*"],
      "@utils/*": ["./utils/*"],
      "@services/*": ["./services/*"],
      "@api/*": ["./api/*"],
      "@constants/*": ["./constants/*"],
      "@animations/*": ["./animations/*"]
    }
  }
}
